{
  "name": "ai-sdlc-wrapper",
  "version": "1.0.0",
  "description": "AI-powered SDLC workflow automation with IBM Bob",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-sdlc": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
